@{
    ViewData["Title"] = "Dashboard";
}

<h1>Welcome to Skyline Realtor!</h1>

@if (Context.Session.GetString("IsLoggedIn") == "true")
{
    <p>Welcome back, <strong>@Context.Session.GetString("UserEmail")</strong>!</p>

    <div style="margin-top: 40px;">
        <h2>Quick Stats</h2>
        <div style="display: flex; gap: 20px; margin-top: 20px;">
            <div style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 20px; border-radius: 15px; text-align: center; flex: 1;">
                <h3 style="font-size: 2rem;" id="agentCount">0</h3>
                <p>Agents</p>
            </div>
            <div style="background: linear-gradient(135deg, #f093fb, #f5576c); color: white; padding: 20px; border-radius: 15px; text-align: center; flex: 1;">
                <h3 style="font-size: 2rem;" id="clientCount">0</h3>
                <p>Clients</p>
            </div>
            <div style="background: linear-gradient(135deg, #4facfe, #00f2fe); color: white; padding: 20px; border-radius: 15px; text-align: center; flex: 1;">
                <h3 style="font-size: 2rem;" id="propertyCount">0</h3>
                <p>Properties</p>
            </div>
        </div>
    </div>

    <div style="margin-top: 40px;">
        <h2>Recent Activity</h2>
        <p>Use the navigation menu above to manage agents, clients, and properties.</p>
        <ul style="margin-top: 10px; color: #666;">
            <li>➕ Add new agents, clients, or properties</li>
            <li>📋 View and manage all records</li>
            <li>🔐 Your session is secure</li>
        </ul>
    </div>
}
else
{
    <p>Please <a href="/Home/Login">login</a> to access the system.</p>
}