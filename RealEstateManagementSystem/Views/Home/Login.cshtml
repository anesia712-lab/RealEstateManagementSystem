@{
    ViewData["Title"] = "Login";
}

<h1>Skyline Realtor Login</h1>

<form asp-action="Login" asp-controller="Home" method="post">
    <div class="form-field">
        <label for="email">Email</label>
        <input type="email" name="email" id="email" required autocomplete="username" aria-describedby="login-hint" />
    </div>
    <div class="form-field">
        <label for="password">Password</label>
        <input type="password" name="password" id="password" required autocomplete="current-password" />
    </div>
    <button type="submit">Sign in</button>
</form>

<p id="login-hint" class="hint"><small>Demo (if seeded): admin@realtor.com / 1234</small></p>

<p>Don't have an account? <a href="/Home/SignUp">Create an account</a></p>
