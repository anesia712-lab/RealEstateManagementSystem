@model List<RealEstateManagementSystem.Models.Property>

<h2>All Properties</h2>

<a href="/Properties/Add">Add New Property</a>

@if (Model != null && Model.Any())
{
    <table border="1" style="width: 100%; border-collapse: collapse; margin-top: 20px;">
        <thead>
            <tr>
                <th style="padding: 10px; background: #667eea; color: white;">Address</th>
                <th style="padding: 10px; background: #667eea; color: white;">Price</th>
                <th style="padding: 10px; background: #667eea; color: white;">Bedrooms</th>
                <th style="padding: 10px; background: #667eea; color: white;">Bathrooms</th>
                <th style="padding: 10px; background: #667eea; color: white;">Square Feet</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var property in Model)
            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;"><a href="/Properties/Details/@property.Id">@property.Address</a></td>
                    <td style="padding: 8px; border: 1px solid #ddd;">$@property.Price.ToString("N0")</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@property.Bedrooms</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@property.Bathrooms</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@property.SquareFeet</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No properties yet. Add your first property!</p>
}