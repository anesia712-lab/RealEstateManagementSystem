@model RealEstateManagementSystem.Models.Property

@{
    ViewData["Title"] = "Add Property";
}

<h2>➕ Add New Property</h2>

<form asp-controller="Properties" asp-action="Add" method="post">
    <div asp-validation-summary="All" class="validation-summary-all" role="alert"></div>

    <div class="form-field">
        <label asp-for="Address">Property Address</label>
        <input asp-for="Address" required />
        <span asp-validation-for="Address" class="field-validation-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="Price">Price ($)</label>
        <input asp-for="Price" type="number" step="1000" required min="1000" />
        <small class="hint">Between $1,000 and $100,000,000</small>
        <span asp-validation-for="Price" class="field-validation-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="Bedrooms">Bedrooms</label>
        <input asp-for="Bedrooms" type="number" required min="1" max="50" />
        <span asp-validation-for="Bedrooms" class="field-validation-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="Bathrooms">Bathrooms</label>
        <input asp-for="Bathrooms" type="number" required min="1" max="50" step="1" />
        <small class="hint">Whole numbers only in this version (e.g. 2)</small>
        <span asp-validation-for="Bathrooms" class="field-validation-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="SquareFeet">Square Feet</label>
        <input asp-for="SquareFeet" type="number" required min="100" max="50000" />
        <span asp-validation-for="SquareFeet" class="field-validation-error"></span>
    </div>

    <button type="submit">Save Property</button>
    <a href="/Properties/Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
