@model RealEstateManagementSystem.Models.ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="page-error">
    <h1>We hit a snag</h1>
    <p class="lead">@Model.UserMessage</p>

    @if (Model.ShowRequestId)
    {
        <p class="error-ref">If you need help, share this reference ID: <strong><code>@Model.RequestId</code></strong></p>
    }

    @if (Model.ShowTechnicalDetail)
    {
        <details class="technical-details">
            <summary>Technical details (development)</summary>
            <pre>@Model.TechnicalDetail</pre>
        </details>
    }

    <p class="error-actions">
        <a href="/" class="btn-link">Return to home</a>
        <span> · </span>
        <a href="javascript:history.back()" class="btn-link">Go back</a>
    </p>
</div>
