<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Skyline Realtor</title>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- Navigation Bar -->
    <nav>
        <a href="/"><i class="fas fa-building"></i> Skyline Realtor</a>

        @if (Context.Session.GetString("IsLoggedIn") == "true")
        {
            <a href="/Agents/Add"><i class="fas fa-user-plus"></i> Add Agent</a>
            <a href="/Agents/Index"><i class="fas fa-users"></i> View Agents</a>
            <a href="/Clients/Add"><i class="fas fa-user-plus"></i> Add Client</a>
            <a href="/Clients/Index"><i class="fas fa-users"></i> View Clients</a>
            <a href="/Properties/Add"><i class="fas fa-home"></i> Add Property</a>
            <a href="/Properties/Index"><i class="fas fa-list"></i> View Properties</a>
            <a href="/Home/Privacy"><i class="fas fa-shield-alt"></i> Privacy</a>
            <a href="/Home/Logout" style="color: #f5576c;"><i class="fas fa-sign-out-alt"></i> Logout</a>
            <span style="float: right; margin-left: 20px;">
                <i class="fas fa-user-circle"></i> @Context.Session.GetString("UserEmail")
            </span>
        }
        else
        {
            <a href="/Home/Login"><i class="fas fa-sign-in-alt"></i> Login</a>
            <a href="/Home/SignUp"><i class="fas fa-user-plus"></i> Sign Up</a>
            <a href="/Home/Privacy"><i class="fas fa-shield-alt"></i> Privacy</a>
        }
    </nav>

    <!-- Main Content Container -->
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

</body>
</html>
