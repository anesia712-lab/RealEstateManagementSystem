@model RealEstateManagementSystem.Models.Client

<h2>➕ Add New Client</h2>

<form method="post">
    <div>
        <label>Full Name:</label>
        <input asp-for="FullName" required />
    </div>
    <br />

    <div>
        <label>Phone Number:</label>
        <input asp-for="PhoneNumber" required />
    </div>
    <br />

    <div>
        <label>Email:</label>
        <input asp-for="Email" type="email" required />
    </div>
    <br />

    <div>
        <label>Physical Address:</label>
        <input asp-for="Address" required />
    </div>
    <br />

    <button type="submit">Save Client</button>
    <a href="/Clients/Index">Cancel</a>
</form>
