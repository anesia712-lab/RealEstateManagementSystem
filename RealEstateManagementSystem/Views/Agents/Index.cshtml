@model List<RealEstateManagementSystem.Models.Agent>

<h2>📋 All Agents</h2>

<a href="/Agents/Add">➕ Add New Agent</a>

<table border="1" style="border-collapse: collapse; width: 100%; margin-top: 20px;">
    <thead style="background-color: #f0f0f0;">
        <tr>
            <th>ID</th>
            <th>Full Name</th>
            <th>License Number</th>
            <th>Email</th>
            <th>Phone</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var agent in Model)
            {
                <tr>
                    <td>@agent.Id</td>
                    <td>@agent.FullName</td>
                    <td>@agent.LicenseNumber</td>
                    <td>@agent.Email</td>
                    <td>@agent.PhoneNumber</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" style="text-align: center;">No agents found. Add your first agent!</td>
            </tr>
        }
    </tbody>
</table>

<br />
<a href="/">← Back to Home</a>

