<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Session" Version="2.3.9" />
    <PackageReference Include="Microsoft.VisualStudio.Web.CodeGeneration.Design" Version="8.0.23" />
    <!-- Add SQL Server client package so Microsoft.Data.SqlClient and related types are available -->
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.1" />
      <!-- BCrypt for verifying password hashes stored in the Users table -->
      <PackageReference Include="BCrypt.Net-Next" Version="4.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="wwwroot\NewFolder\" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="DesktopApp\**" />
    <Content Remove="DesktopApp\**" />
    <EmbeddedResource Remove="DesktopApp\**" />
    <None Remove="DesktopApp\**" />
    
    <Compile Remove="Module2_ClassLibrary\**" />
    <Content Remove="Module2_ClassLibrary\**" />
    <EmbeddedResource Remove="Module2_ClassLibrary\**" />
    <None Remove="Module2_ClassLibrary\**" />
  </ItemGroup>

</Project>
